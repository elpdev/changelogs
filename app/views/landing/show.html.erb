<section class="border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="max-w-2xl">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white leading-[1.1]">
        What shipped in
        <span class="text-emerald-500">open source</span>
        today
      </h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        Curated release notes, changelogs, and developer news from the
        projects you care about.
      </p>
      <div class="mt-6">
        <%= link_to "Browse projects", projects_path,
          class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg text-white bg-emerald-600 hover:bg-emerald-700 transition-colors" %>
      </div>
    </div>
  </div>
</section>

<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 font-mono">
      Latest
    </h2>
  </div>

  <% if @articles.any? %>
    <div class="divide-y divide-gray-100 dark:divide-gray-800">
      <% @articles.each do |article| %>
        <%= render "articles/card", article: article %>
      <% end %>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="mt-8 flex justify-center">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-500 dark:text-gray-400 text-center py-12 font-mono">
      No articles yet. Check back soon.
    </p>
  <% end %>
</section>
