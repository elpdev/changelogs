<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Projects</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
      Open source projects tracked by changelogs.news
    </p>
  </div>

  <div class="mb-8">
    <%= search_form_for @q, url: projects_path, class: "flex gap-2" do |f| %>
      <%= f.search_field :name_cont,
        placeholder: "Search projects...",
        class: "flex-1 px-3 py-2 text-sm rounded-lg border border-gray-300 dark:border-gray-700
               bg-white dark:bg-gray-900 text-gray-900 dark:text-white
               placeholder-gray-400 dark:placeholder-gray-500
               focus:ring-2 focus:ring-emerald-500 focus:border-transparent
               font-mono" %>
      <%= f.submit "Search", class: "px-4 py-2 text-sm font-medium rounded-lg
                                     bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300
                                     hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <% if @projects.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% @projects.each do |project| %>
        <%= link_to project_path(project), class: "block" do %>
          <%= render Card::Component.new(border: true, shadow: :none, padding: :md, rounded: :lg,
            extra_classes: "hover:border-emerald-500 dark:hover:border-emerald-500 transition-colors h-full") do %>
            <div>
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-semibold text-gray-900 dark:text-white"><%= project.name %></h3>
                <% if project.language.present? %>
                  <%= render Badge::Component.new(text: project.language, variant: :info, size: :small) %>
                <% end %>
              </div>

              <% if project.description.present? %>
                <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-3">
                  <%= project.description %>
                </p>
              <% end %>

              <div class="flex items-center gap-4 text-xs text-gray-400 dark:text-gray-500 font-mono">
                <% if project.stars_count > 0 %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <%= number_to_human(project.stars_count, precision: 1, significant: true, format: "%n%u",
                                        units: {thousand: "k", million: "M"}) %>
                  </span>
                <% end %>
                <span><%= project.articles_count %> <%= "article".pluralize(project.articles_count) %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="mt-8 flex justify-center">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-500 dark:text-gray-400 text-center py-12 font-mono">
      No projects yet. Check back soon.
    </p>
  <% end %>
</section>
