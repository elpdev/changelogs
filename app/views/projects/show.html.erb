<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-10">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @project.name %></h1>
        <% if @project.description.present? %>
          <p class="mt-2 text-gray-600 dark:text-gray-400 max-w-2xl">
            <%= @project.description %>
          </p>
        <% end %>
      </div>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-3">
      <% if @project.language.present? %>
        <%= render Badge::Component.new(text: @project.language, variant: :info, size: :medium) %>
      <% end %>
      <% if @project.stars_count > 0 %>
        <span class="flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 font-mono">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <%= number_to_human(@project.stars_count, precision: 1, significant: true, format: "%n%u",
                              units: {thousand: "k", million: "M"}) %>
        </span>
      <% end %>
      <span class="text-sm text-gray-500 dark:text-gray-400 font-mono">
        <%= @project.articles_count %> <%= "article".pluralize(@project.articles_count) %>
      </span>
      <% if @project.github_url.present? %>
        <a href="<%= @project.github_url %>" target="_blank" rel="noopener"
           class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400
                  hover:text-gray-700 dark:hover:text-gray-200 transition-colors font-mono">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          View on GitHub
        </a>
      <% end %>
    </div>
  </div>

  <div>
    <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 font-mono mb-6">
      Articles
    </h2>

    <% if @articles.any? %>
      <div class="divide-y divide-gray-100 dark:divide-gray-800">
        <% @articles.each do |article| %>
          <%= render "articles/card", article: article %>
        <% end %>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-8 flex justify-center">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-500 dark:text-gray-400 text-center py-12 font-mono">
        No articles yet for this project.
      </p>
    <% end %>
  </div>
</section>
